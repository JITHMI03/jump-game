[gd_scene format=3 uid="uid://settings_scene"]

[ext_resource type="Script" path="res://scene/settings.gd" id="1_settings_script"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.08, 0.08, 0.15, 0.95)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.4, 0.6, 1, 0.8)
corner_radius_top_left = 12
corner_radius_top_right = 12
corner_radius_bottom_right = 12
corner_radius_bottom_left = 12

[node name="settings" type="Node"]
script = ExtResource("1_settings_script")

[node name="SettingsPanel" type="Panel" parent="."]
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -200.0
offset_right = 200.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="VBoxContainer" type="VBoxContainer" parent="SettingsPanel"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -170.0
offset_top = -170.0
offset_right = 170.0
offset_bottom = 170.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="title" type="Label" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 30
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "Settings"
horizontal_alignment = 1

[node name="master_row" type="HBoxContainer" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2

[node name="master_lbl" type="Label" parent="SettingsPanel/VBoxContainer/master_row"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "Volume"

[node name="master_slider" type="HSlider" parent="SettingsPanel/VBoxContainer/master_row"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.0
max_value = 1.0
step = 0.05
value = 1.0

[node name="sfx_row" type="HBoxContainer" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2

[node name="sfx_lbl" type="Label" parent="SettingsPanel/VBoxContainer/sfx_row"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "SFX"

[node name="sfx_slider" type="HSlider" parent="SettingsPanel/VBoxContainer/sfx_row"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.0
max_value = 1.0
step = 0.05
value = 1.0

[node name="touch_row" type="HBoxContainer" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2

[node name="touch_lbl" type="Label" parent="SettingsPanel/VBoxContainer/touch_row"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "Touch UI"

[node name="touch_toggle" type="CheckButton" parent="SettingsPanel/VBoxContainer/touch_row"]
layout_mode = 2
button_pressed = true
text = "On"

[node name="difficulty_row" type="HBoxContainer" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2

[node name="difficulty_lbl" type="Label" parent="SettingsPanel/VBoxContainer/difficulty_row"]
layout_mode = 2
custom_minimum_size = Vector2(100, 0)
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "Difficulty"

[node name="difficulty_btn" type="OptionButton" parent="SettingsPanel/VBoxContainer/difficulty_row"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 18

[node name="close_btn" type="Button" parent="SettingsPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Close"

[connection signal="value_changed" from="SettingsPanel/VBoxContainer/master_row/master_slider" to="." method="_on_master_slider_value_changed"]
[connection signal="value_changed" from="SettingsPanel/VBoxContainer/sfx_row/sfx_slider" to="." method="_on_sfx_slider_value_changed"]
[connection signal="toggled" from="SettingsPanel/VBoxContainer/touch_row/touch_toggle" to="." method="_on_touch_toggle_toggled"]
[connection signal="item_selected" from="SettingsPanel/VBoxContainer/difficulty_row/difficulty_btn" to="." method="_on_difficulty_btn_item_selected"]
[connection signal="pressed" from="SettingsPanel/VBoxContainer/close_btn" to="." method="_on_close_pressed"]
