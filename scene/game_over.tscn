[gd_scene format=3 uid="uid://game_over_scene"]

[ext_resource type="Script" path="res://scene/game_over.gd" id="1_go_script"]

[node name="game_over" type="Node"]
script = ExtResource("1_go_script")

[node name="GameOverPanel" type="Panel" parent="."]
visible = false
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="GameOverPanel"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -110.0
offset_right = 160.0
offset_bottom = 110.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 20

[node name="Label" type="Label" parent="GameOverPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 60
theme_override_colors/font_color = Color(1, 0.2, 0.2, 1)
text = "GAME OVER"
horizontal_alignment = 1

[node name="score_label" type="Label" parent="GameOverPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Score: 0"
horizontal_alignment = 1

[node name="restart" type="Button" parent="GameOverPanel/VBoxContainer"]
process_mode = 3
layout_mode = 2
theme_override_font_sizes/font_size = 30
text = "Restart"

[node name="menu" type="Button" parent="GameOverPanel/VBoxContainer"]
process_mode = 3
layout_mode = 2
theme_override_font_sizes/font_size = 30
text = "Main Menu"

[connection signal="pressed" from="GameOverPanel/VBoxContainer/restart" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="GameOverPanel/VBoxContainer/menu" to="." method="_on_menu_pressed"]
